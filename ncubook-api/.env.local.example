# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# Admin / Cron
# ADMIN_TOKEN protects the campus information operations console and write APIs.
# CRON_SECRET protects /api/cron/crawl-official-sources. Vercel Cron can also use
# the Authorization Bearer secret if configured externally.
ADMIN_TOKEN=your-admin-token
OPS_READ_TOKEN=your-ops-read-token
CRON_SECRET=your-cron-secret

# Lark / Feishu feedback sync
# Production bot sync is disabled by default because this Base currently accepts
# user identity writes but not app/bot writes. Use `npm run sync:feishu` locally
# after logging into lark-cli as your user to mirror Supabase records into Feishu.
LARK_APP_ID=your-lark-app-id
LARK_APP_SECRET=your-lark-app-secret
LARK_FEEDBACK_BASE_TOKEN=EgvkbmspHaTCdes74AvcsL64nGg
LARK_FEEDBACK_TABLE_ID=tbllSr5HwymQ2YAq
LARK_FEEDBACK_SYNC_ENABLED=false

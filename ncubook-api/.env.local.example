# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Model providers
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# OpenAI-compatible relay. If OPENAI_COMPATIBLE_API_KEY is set, chat and
# embeddings use this provider instead of DeepSeek/Gemini.
OPENAI_COMPATIBLE_BASE_URL=https://your-relay.example.com/v1
OPENAI_COMPATIBLE_API_KEY=your-relay-api-key
OPENAI_COMPATIBLE_CHAT_MODEL=gpt-5.4
OPENAI_COMPATIBLE_WIRE_API=responses
# Only set this if the relay supports embedding models. Otherwise embeddings
# continue to use GOOGLE_GENERATIVE_AI_API_KEY / gemini-embedding-001.
# OPENAI_COMPATIBLE_EMBEDDING_MODEL=text-embedding-3-large

# Admin / Cron
# ADMIN_TOKEN protects the campus information operations console and write APIs.
# CRON_SECRET protects /api/cron/crawl-official-sources. Vercel Cron can also use
# the Authorization Bearer secret if configured externally.
ADMIN_TOKEN=your-admin-token
OPS_READ_TOKEN=your-ops-read-token
CRON_SECRET=your-cron-secret

# Lark / Feishu feedback sync
# Production bot sync is disabled by default because this Base currently accepts
# user identity writes but not app/bot writes. Use `npm run sync:feishu` locally
# after logging into lark-cli as your user to mirror Supabase records into Feishu.
LARK_APP_ID=your-lark-app-id
LARK_APP_SECRET=your-lark-app-secret
LARK_FEEDBACK_BASE_TOKEN=EgvkbmspHaTCdes74AvcsL64nGg
LARK_FEEDBACK_TABLE_ID=tbllSr5HwymQ2YAq
LARK_FEEDBACK_SYNC_ENABLED=false

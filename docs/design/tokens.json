{
  "$description": "此间设计令牌首版。实现时转换为 CSS custom properties 与 Tailwind theme tokens；不得在页面层新增同类值。",
  "color": {
    "canvas": { "$type": "color", "$value": "#F8F5EE" },
    "surface": { "$type": "color", "$value": "#FFFFFF" },
    "surfaceSubtle": { "$type": "color", "$value": "#F0EDE5" },
    "text": { "$type": "color", "$value": "#171915" },
    "textMuted": { "$type": "color", "$value": "#676B61" },
    "border": { "$type": "color", "$value": "#DFD8CC" },
    "action": { "$type": "color", "$value": "#0A6B4E" },
    "actionSubtle": { "$type": "color", "$value": "#DCEFE6" },
    "info": { "$type": "color", "$value": "#2E5F87" },
    "warning": { "$type": "color", "$value": "#9B5A12" },
    "danger": { "$type": "color", "$value": "#9F3D2E" },
    "focus": { "$type": "color", "$value": "#0A6B4E" }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "24px" },
    "6": { "$type": "dimension", "$value": "32px" },
    "7": { "$type": "dimension", "$value": "48px" }
  },
  "fontSize": {
    "caption": { "$type": "dimension", "$value": "12px" },
    "label": { "$type": "dimension", "$value": "14px" },
    "body": { "$type": "dimension", "$value": "16px" },
    "bodyLarge": { "$type": "dimension", "$value": "18px" },
    "title": { "$type": "dimension", "$value": "22px" },
    "heading": { "$type": "dimension", "$value": "28px" },
    "display": { "$type": "dimension", "$value": "36px" }
  },
  "fontFamily": {
    "ui": { "$type": "fontFamily", "$value": "Avenir Next, PingFang SC, Hiragino Sans GB, Microsoft YaHei, sans-serif" },
    "body": { "$type": "fontFamily", "$value": "PingFang SC, Hiragino Sans GB, Microsoft YaHei, sans-serif" }
  },
  "fontWeight": {
    "regular": { "$type": "fontWeight", "$value": 400 },
    "medium": { "$type": "fontWeight", "$value": 500 },
    "semibold": { "$type": "fontWeight", "$value": 600 },
    "bold": { "$type": "fontWeight", "$value": 700 }
  },
  "lineHeight": {
    "ui": { "$type": "number", "$value": 1.4 },
    "body": { "$type": "number", "$value": 1.7 },
    "heading": { "$type": "number", "$value": 1.25 }
  },
  "radius": {
    "small": { "$type": "dimension", "$value": "8px" },
    "medium": { "$type": "dimension", "$value": "12px" },
    "large": { "$type": "dimension", "$value": "16px" },
    "round": { "$type": "dimension", "$value": "999px" }
  },
  "size": {
    "iconSmall": { "$type": "dimension", "$value": "16px" },
    "icon": { "$type": "dimension", "$value": "20px" },
    "iconLarge": { "$type": "dimension", "$value": "24px" },
    "tapTarget": { "$type": "dimension", "$value": "44px" }
  },
  "borderWidth": {
    "default": { "$type": "dimension", "$value": "1px" }
  },
  "shadow": {
    "floating": { "$type": "shadow", "$value": "0 8px 24px rgba(23, 25, 21, 0.14)" }
  },
  "zIndex": {
    "base": { "$type": "number", "$value": 0 },
    "header": { "$type": "number", "$value": 10 },
    "floatingAction": { "$type": "number", "$value": 20 },
    "drawer": { "$type": "number", "$value": 30 },
    "modal": { "$type": "number", "$value": 40 }
  },
  "motion": {
    "fast": { "$type": "duration", "$value": "120ms" },
    "standard": { "$type": "duration", "$value": "200ms" }
  }
}

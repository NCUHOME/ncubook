# Notion content operations
#
# 1. Create an internal integration in Notion.
# 2. Copy its Internal Integration Secret into NOTION_TOKEN.
# 3. Share the "此间内容库" database page with that integration.
# 4. Copy the database id from the Notion database URL into NOTION_CONTENT_DATABASE_ID.

NOTION_TOKEN=secret_xxx
NOTION_CONTENT_DATABASE_ID=your-notion-database-id
